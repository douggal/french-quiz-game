{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug quiz game (interactive)",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--bin=french_quiz_game",
                    "--package=french_quiz_game"
                ],
                "filter": {
                    "name": "french_quiz_game",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}",
            "terminal": "integrated"
        },
        {
            "name": "Debug unit tests in executable 'french_quiz_game'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=french_quiz_game",
                    "--package=french_quiz_game"
                ],
                "filter": {
                    "name": "french_quiz_game",
                    "kind": "bin"
                }
            },
            "cwd": "${workspaceFolder}",
            "terminal": "integrated"
        },
        {
            "name": "Debug unit tests in library 'french_quiz_game'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--lib",
                    "--package=french_quiz_game"
                ],
                "filter": {
                    "name": "french_quiz_game",
                    "kind": "lib"
                }
            },
            "cwd": "${workspaceFolder}",
            "terminal": "integrated"
        },
        {
            "name": "Debug integration test 'tests'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--test=tests",
                    "--package=french_quiz_game"
                ],
                "filter": {
                    "name": "tests",
                    "kind": "test"
                }
            },
            "cwd": "${workspaceFolder}",
            "terminal": "integrated"
        }
    ]
}